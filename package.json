{
  "name": "jam-leaderboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:full": "npm run update-all-data && next build",
    "start": "next start",
    "collect": "node scripts/run_python.js scripts/collect_evaluations.py --refresh-notion --no-download",
    "normalize": "node scripts/run_python.js scripts/normalize_reports.py",
    "build-data": "node scripts/run_python.js scripts/build_frontend_data.py",
    "report": "node scripts/run_python.js scripts/report_summary.py",
    "update-all-data": "npm run collect && npm run normalize && npm run build-data && npm run report"
  },
  "dependencies": {
    "@polkadot/api": "^16.5.6",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.542.0",
    "next": "15.5.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4.1.12",
    "typescript": "^5"
  }
}
